server:
  port: 8081

spring:
  application:
    name: user-service
  datasource:
    url: jdbc:postgresql://localhost:5432/airsync_users
    username: postgres
    password: 1212  # replace with your actual postgres password
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update  # auto creates tables on startup
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect

jwt:
  secret: airsync-super-secret-key-thomson-2024-make-this-long
  expiration: 86400000 # 24 hours in milliseconds
